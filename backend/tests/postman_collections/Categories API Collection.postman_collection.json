  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Pre-request script for setting up variables",
          "// You can add logic here to dynamically set data",
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Test script for Categories API",
          "pm.test(\"Status code is 200\", function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test(\"Response is JSON\", function () {",
          "    pm.response.to.be.json;",
          "});",
          "",
          "// For GET all categories endpoint",
          "if (pm.request.url.path.includes('/categories') && pm.request.method === 'GET' && !pm.request.url.path.includes('/categories/')) {",
          "    pm.test(\"Response should be an array\", function () {",
          "        pm.expect(pm.response.json()).to.be.an('array');",
          "    });",
          "}",
          "",
          "// For GET single category endpoint",
          "if (pm.request.url.path.match(/\\/categories\\/\\d+$/)) {",
          "    pm.test(\"Response should have category properties\", function () {",
          "        var responseData = pm.response.json();",
          "        if (responseData && !responseData.message) {",
          "            pm.expect(responseData).to.have.property('id');",
          "            pm.expect(responseData).to.have.property('name');",
          "        }",
          "    });",
          "}",
          "",
          "// For POST request (create category)",
          "if (pm.request.method === 'POST') {",
          "    pm.test(\"Status code is 201 (Created)\", function () {",
          "        pm.response.to.have.status(201);",
          "    });",
          "    ",
          "    // Save the created category ID for future requests",
          "    if (pm.response.code === 201) {",
          "        var responseData = pm.response.json();",
          "        if (responseData.id) {",
          "            pm.environment.set(\"category_id\", responseData.id);",
          "            console.log(\"Category ID saved:\", responseData.id);",
          "        }",
          "    }",
          "}",
          "",
          "// For DELETE request",
          "if (pm.request.method === 'DELETE') {",
          "    pm.test(\"Delete successful\", function () {",
          "        var responseData = pm.response.json();",
          "        pm.expect(responseData).to.have.property('message');",
          "        pm.expect(responseData.message).to.include('deleted');",
          "    });",
          "}"
        ]
      }
    }
